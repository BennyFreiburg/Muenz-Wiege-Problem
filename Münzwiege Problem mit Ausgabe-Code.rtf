      public static int weigh(int[] coins, int[] left, int[] right) \{\par
        int leftSum = 0, rightSum = 0;\par
        for (int i : left) leftSum += coins[i];\par
        for (int i : right) rightSum += coins[i];\par
        if (leftSum < rightSum) return -1;\par
        if (leftSum > rightSum) return 1;\par
        return 0;\par
    \}\par
